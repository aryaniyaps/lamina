      "prompt": "/lamina-audit — Audit our app.",
      "force_skill_invocation": true,
      "fixture": "brownfield-audit-ready",
      "stage_files": true,
      "assertions": [
        "turn 1 output contains \"Clarifying questions\"",
        "audit contract headings",
        "artifact pack exists",
        "implement.md exists"
      ]
