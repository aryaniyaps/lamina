# LaminaBench — Anthropic / gateway credentials (copy to .env)
#
# Claude Code agent (bench:run) reads ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN + ANTHROPIC_MODEL.
# Rewardkit LLM judge in Harbor verifiers uses the same credentials via task.toml [verifier.env].

export ANTHROPIC_BASE_URL="https://your-gateway.example.com"
export ANTHROPIC_AUTH_TOKEN="your-gateway-token"
export ANTHROPIC_MODEL="lx1-sonnet-4.6"
