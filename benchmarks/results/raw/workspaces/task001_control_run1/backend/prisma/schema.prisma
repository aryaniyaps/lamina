generator client {
  provider = "prisma-client-js"
}

 datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
 }

/// Core entities as per implementation plan
model User {
  id          String   @id @default(uuid())
  email       String   @unique
  phone       String?  @unique
  name        String?
  passwordHash String
  mfaEnabled  Boolean  @default(false)
  createdAt   DateTime @default(now())
  persona     Persona?
  memberships HouseholdMembership[]
  alerts      Alert[]
  preferences NotificationPreference?
}

model Persona {
  id            String @id @default(uuid())
  userId        String @unique
  displayName   String
  avatarUrl     String?
  consentToDataUse Boolean @default(false)
  user          User   @relation(fields: [userId], references: [id])
}

model Household {
  id               String   @id @default(uuid())
  name             String
  createdAt        DateTime @default(now())
  defaultCurrency  String   @default("USD")
  memberships      HouseholdMembership[]
  accounts         Account[]
  budgets          Budget[]
  alerts           Alert[]
  inviteTokens     InviteToken[]
}

model HouseholdMembership {
  householdId String
  userId      String
  role        Role
  joinedAt    DateTime @default(now())
  status      MembershipStatus @default("active")

  household Household @relation(fields: [householdId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@id([householdId, userId])
  @@unique([householdId, userId])
}

enum Role {
  OWNER
  PARTNER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  REMOVED
}

model Budget {
  id          String   @id @default(uuid())
  householdId String
  startMonth  DateTime // first day of month
  status      BudgetStatus @default(DRAFT)
  version     Int @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household   Household @relation(fields: [householdId], references: [id])
  periods     BudgetPeriod[]
  categories  Category[]
  incomeSources IncomeSource[]
  adjustments BudgetAdjustment[]

  @@unique([householdId, status], map: "unique_active_budget_per_household", where: "status = 'ACTIVE'")
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model BudgetPeriod {
  id        String   @id @default(uuid())
  budgetId  String
  month     DateTime // first day of month
  state     PeriodState @default(PLANNING)
  rolloverCents Int @default(0)

  budget    Budget @relation(fields: [budgetId], references: [id])
  @@unique([budgetId, month])
}

enum PeriodState {
  PLANNING
  OPEN
  CLOSED
}

model Category {
  id               String   @id @default(uuid())
  budgetId         String
  name             String
  type             CategoryType
  privacyLevel     PrivacyLevel @default(SHARED)
  allocationCents  Int @default(0)

  budget            Budget @relation(fields: [budgetId], references: [id])
  transactions      Transaction[]

  @@unique([budgetId, name])
}

enum CategoryType {
  FIXED
  FLEXIBLE
  SAVINGS
  PERSONAL
}

enum PrivacyLevel {
  SHARED
  PERSONAL
}

model IncomeSource {
  id          String   @id @default(uuid())
  budgetId    String
  name        String
  amountCents Int
  frequency   IncomeFrequency
  startDate   DateTime
  endDate     DateTime?

  budget      Budget @relation(fields: [budgetId], references: [id])
}

enum IncomeFrequency {
  ONE_TIME
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

model Account {
  id                 String   @id @default(uuid())
  householdId        String
  name               String
  type               AccountType
  mask               String   // last 4 digits
  externalAccountId  String   @unique
  institutionId      String
  status             AccountStatus @default(ACTIVE)

  household          Household @relation(fields: [householdId], references: [id])
  transactions       Transaction[]
  syncJobs           SyncJob[]
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  LOAN
  CASH
}

enum AccountStatus {
  ACTIVE
  DISCONNECTED
  ERROR
}

model Transaction {
  id                     String   @id @default(uuid())
  accountId              String
  externalTransactionId  String?  @unique
  amountCents            Int
  postedAt               DateTime
  description            String?
  merchantName           String?
  categoryId             String?
  status                 TransactionStatus @default(POSTED)
  duplicateHash          String? // for fuzzy duplicate detection

  account                Account @relation(fields: [accountId], references: [id])
  category               Category? @relation(fields: [categoryId], references: [id])
}

enum TransactionStatus {
  POSTED
  PENDING
  EXCLUDED
  DUPLICATE
}

model Alert {
  id          String   @id @default(uuid())
  householdId String
  userId      String
  type        AlertType
  status      AlertStatus @default(UNREAD)
  payload     Json?
  createdAt   DateTime @default(now())

  household   Household @relation(fields: [householdId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

enum AlertType {
  OVER_BUDGET
  TRANSACTION_THRESHOLD
  ACCOUNT_SYNC
  PARTNER_ACTION
  LOW_BALANCE
}

enum AlertStatus {
  UNREAD
  DISMISSED
  RESOLVED
}

model SyncJob {
  id                String   @id @default(uuid())
  accountId         String
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  status            SyncStatus @default(PENDING)
  errorCode         String?
  transactionsAdded Int @default(0)
  retries           Int @default(0)

  account           Account @relation(fields: [accountId], references: [id])
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

model InviteToken {
  id           String   @id @default(uuid())
  householdId  String
  invitedEmail String
  role         Role
  expiresAt    DateTime
  acceptedBy   String? // userId
  createdAt    DateTime @default(now())

  household    Household @relation(fields: [householdId], references: [id])
}

model BudgetAdjustment {
  id          String   @id @default(uuid())
  budgetId    String
  categoryId  String
  amountCents Int
  reason      String?
  actorUserId String
  createdAt   DateTime @default(now())

  budget      Budget   @relation(fields: [budgetId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])
  actor       User     @relation(fields: [actorUserId], references: [id])
}

model NotificationPreference {
  id            String   @id @default(uuid())
  userId        String   @unique
  pushEnabled   Boolean  @default(true)
  quietHoursStart Int?   // hour in 0-23
  quietHoursEnd   Int?   // hour in 0-23
  largeTxnThresholdCents Int @default(20000) // $200 default

  user          User @relation(fields: [userId], references: [id])
}

/// Add any additional models needed for audit logs, etc.
