{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LaminaBench Golden Specification",
  "type": "object",
  "required": ["task_id"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task[0-9]{3}$"
    },
    "required_personas": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Actors / user roles that must be addressed"
    },
    "required_flows": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_rules": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Testable product rules"
    },
    "required_edge_cases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_a11y": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_sections": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Contract narrative structure (domain, actors, workflows, scenarios, implement brief)"
    },
    "required_findings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "For audit tasks: behavior gaps and invariant/consistency failures to discover"
    },
    "required_invariants": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Illegal states that must be unrepresentable or explicitly guarded"
    },
    "required_entities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Domain entities and relationships"
    },
    "required_tradeoffs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Named trade-offs between competing product/system goals"
    },
    "required_scenarios": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Violation attempts and recovery paths tied to invariants"
    }
  },
  "additionalProperties": false
}
