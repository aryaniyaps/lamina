{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["task_id", "arm", "track", "cohort_id", "repeat", "protocol_hash", "cell_input_hash", "contract_score", "transfer_score", "contract_critical_omissions", "contract_critical_failures", "transfer_critical_omissions", "transfer_critical_failures", "incomplete", "time_to_threshold", "rework_tokens", "rework_tool_calls"],
  "properties": {
    "task_id": { "type": "string" },
    "arm": { "enum": ["raw", "structured", "lamina"] },
    "track": { "enum": ["autonomous", "oracle"] },
    "cohort_id": { "type": "string" },
    "repeat": { "type": "integer", "minimum": 1 },
    "protocol_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "cell_input_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "contract_score": { "type": ["number", "null"] },
    "contract_model_score": { "type": ["number", "null"] },
    "main_after_implement_score": { "type": ["number", "null"] },
    "main_after_fix_score": { "type": ["number", "null"] },
    "transfer_after_implement_score": { "type": ["number", "null"] },
    "transfer_after_fix_score": { "type": ["number", "null"] },
    "transfer_score": { "type": ["number", "null"] },
    "contract_critical_omissions": { "type": ["integer", "number", "null"], "minimum": 0 },
    "contract_critical_failures": { "type": ["integer", "number", "null"], "minimum": 0 },
    "transfer_critical_omissions": { "type": ["integer", "number", "null"], "minimum": 0 },
    "transfer_critical_failures": { "type": ["integer", "number", "null"], "minimum": 0 },
    "incomplete": { "type": "boolean" },
    "time_to_threshold": { "type": ["number", "null"], "minimum": 0 },
    "rework_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "rework_tool_calls": { "type": ["integer", "null"], "minimum": 0 }
  }
}
