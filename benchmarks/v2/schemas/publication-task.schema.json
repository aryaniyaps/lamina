{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "version", "kind", "fixture_ref", "fixture_sha256"],
  "properties": {
    "task_id": { "type": "string" },
    "version": { "type": "string" },
    "kind": { "enum": ["greenfield", "brownfield"] },
    "fixture_ref": { "type": ["string", "null"] },
    "fixture_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
  }
}
