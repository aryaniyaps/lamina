{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "critical_promises", "structural_hazards", "open_policy_decisions", "acceptable_alternatives"],
  "properties": {
    "task_id": { "type": "string" },
    "critical_promises": { "type": "array", "items": { "type": "object", "required": ["id", "description"], "properties": { "id": { "type": "string" }, "description": { "type": "string" } } } },
    "structural_hazards": { "type": "array", "items": { "type": "object", "required": ["id", "description", "severity"], "properties": { "id": { "type": "string" }, "description": { "type": "string" }, "severity": { "enum": ["critical", "major"] } } } },
    "open_policy_decisions": { "type": "array", "items": { "type": "object" } },
    "acceptable_alternatives": { "type": "array", "items": { "type": "object", "required": ["decision", "acceptable_if"], "properties": { "decision": { "type": "string" }, "acceptable_if": { "type": "string" } } } }
  }
}
