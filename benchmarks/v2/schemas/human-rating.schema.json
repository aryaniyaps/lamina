{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "rater_id", "dimensions", "critical_omissions", "critical_failures", "confidence"],
  "properties": {
    "artifact_id": { "type": "string" },
    "rater_id": { "type": "string" },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical_product_shape", "entity_lifecycle_coherence", "authority_and_ownership", "workflow_reachability", "dependencies_and_invariants", "failure_and_recovery", "decision_discipline", "implementation_actionability", "relevance_and_minimality", "perspective_grounding_and_provenance"],
      "properties": {
        "critical_product_shape": { "$ref": "#/$defs/score" },
        "entity_lifecycle_coherence": { "$ref": "#/$defs/score" },
        "authority_and_ownership": { "$ref": "#/$defs/score" },
        "workflow_reachability": { "$ref": "#/$defs/score" },
        "dependencies_and_invariants": { "$ref": "#/$defs/score" },
        "failure_and_recovery": { "$ref": "#/$defs/score" },
        "decision_discipline": { "$ref": "#/$defs/score" },
        "implementation_actionability": { "$ref": "#/$defs/score" },
        "relevance_and_minimality": { "$ref": "#/$defs/score" },
        "perspective_grounding_and_provenance": { "$ref": "#/$defs/score" }
      }
    },
    "critical_omissions": {
      "type": "array",
      "items": { "type": "object", "required": ["description", "severity"], "properties": { "description": { "type": "string" }, "severity": { "enum": ["critical", "major", "minor"] }, "contract_ref": { "type": ["string", "null"] } } }
    },
    "critical_failures": { "type": "array", "items": { "type": "string" } },
    "confidence": { "enum": ["low", "medium", "high"] },
    "notes": { "type": "string" }
  },
  "$defs": { "score": { "type": "integer", "minimum": 1, "maximum": 5 } }
}
