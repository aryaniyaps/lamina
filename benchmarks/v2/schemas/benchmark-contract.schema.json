{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Neutral product implementation contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "status", "intent", "decisions", "actors", "entities", "operations", "workflows", "rules", "dependencies", "surfaces", "scenarios", "traceability"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "ready_to_build"], "description": "ready_to_build invokes the complete semantic readiness contract described on traceability and the critical node definitions: at least one critical promise, actor, entity, operation, workflow, rule, surface, and scenario; all blocking forks resolved; no prerequisite cycles; every critical actor has a reachable entry or activation path; every critical entity has implementable key field contracts; every critical dependency has a condition, concrete current-slice fulfillment, and observable verification; every critical promise is traced to each required critical node kind; all critical operations, workflows, rules, and dependencies are covered by scenarios; and no deferred node is used to satisfy ready traceability." },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["problem", "outcome", "users", "critical_promises", "success_signals", "constraints", "scope"],
      "properties": {
        "problem": { "type": "string", "minLength": 1 },
        "outcome": { "type": "string", "minLength": 1 },
        "users": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "critical_promises": { "type": "array", "items": { "$ref": "#/$defs/promise" } },
        "success_signals": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "scope": {
          "type": "object",
          "required": ["in", "out"],
          "properties": {
            "in": { "type": "array", "items": { "type": "string" } },
            "out": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "decisions": {
      "type": "object",
      "required": ["assumptions", "forks"],
      "properties": {
        "assumptions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
        "forks": { "type": "array", "items": { "$ref": "#/$defs/decision" } }
      }
    },
    "actors": { "type": "array", "items": { "$ref": "#/$defs/actor" } },
    "entities": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "operations": { "type": "array", "items": { "$ref": "#/$defs/operation" } },
    "workflows": { "type": "array", "items": { "$ref": "#/$defs/workflow" } },
    "rules": { "type": "array", "items": { "$ref": "#/$defs/rule" } },
    "dependencies": { "type": "array", "items": { "$ref": "#/$defs/dependency" } },
    "surfaces": { "type": "array", "items": { "$ref": "#/$defs/surface" } },
    "scenarios": { "type": "array", "items": { "$ref": "#/$defs/scenario" } },
    "traceability": {
      "type": "array",
      "description": "At ready_to_build, every critical promise must have a traceability item whose graph_refs include at least one declared critical actor, entity, operation, workflow, rule, surface, and scenario. Deferred nodes cannot satisfy ready traceability.",
      "items": {
        "type": "object",
        "required": ["promise_ref", "graph_refs"],
        "properties": {
          "promise_ref": { "$ref": "#/$defs/ref" },
          "graph_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } }
        }
      }
    }
  },
  "$defs": {
    "ref": { "type": "string", "pattern": "^(promise|actor|entity|operation|workflow|rule|dependency|surface|scenario)\\.[A-Za-z0-9_-]+$" },
    "metadata": {
      "type": "object",
      "required": ["id", "criticality", "source", "confidence", "relevance_reason"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "criticality": { "enum": ["critical", "supporting", "deferred"] },
        "source": { "enum": ["user", "repository", "derived", "assumed", "review_hypothesis"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "relevance_reason": { "type": "string", "minLength": 1 }
      }
    },
    "promise": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        { "type": "object", "required": ["promise"], "properties": { "promise": { "type": "string", "minLength": 1 } } }
      ]
    },
    "decision": {
      "type": "object",
      "required": ["id", "class", "source", "confidence", "statement", "status"],
      "properties": {
        "id": { "type": "string" },
        "class": { "enum": ["structural", "safety_integrity", "reversible_default", "policy_fork", "desirability_hypothesis", "evidence_backed"] },
        "source": { "enum": ["user", "repository", "derived", "assumed", "review_hypothesis"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "statement": { "type": "string" },
        "status": { "enum": ["proposed", "unresolved", "resolved"] },
        "blocking": { "type": "boolean", "description": "A blocking fork must have status resolved before the contract may be ready_to_build." }
      }
    },
    "actor": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        { "type": "object", "required": ["goal", "authority", "permissions"], "properties": { "goal": { "type": "string", "description": "Required and non-empty for every critical actor at ready_to_build." }, "authority": { "type": "string", "minLength": 1, "description": "Trusted identity and authorization basis for critical actors; a client-side selector or public identifier is not authentication." }, "entry_path": { "type": "string", "minLength": 1, "description": "Reachable enrollment, provisioning, activation, or operational-start path in the current product slice; critical actors require this at ready_to_build." }, "owns": { "type": "array", "items": { "type": "string" } }, "permissions": { "type": "array", "items": { "type": "string" } } } },
        { "if": { "properties": { "criticality": { "const": "critical" } }, "required": ["criticality"] }, "then": { "required": ["entry_path"] } }
      ]
    },
    "entity": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        { "type": "object", "required": ["identity", "states", "relationships", "lifecycle_consequences"], "properties": {
          "identity": { "type": "string", "minLength": 1, "description": "Stable identity used across lifecycle transitions and projections." },
          "attributes": { "type": "array", "description": "Implementable key fields and their behavioral, integrity, privacy, or lifecycle contracts; critical entities require at least one at ready_to_build.", "items": { "type": "object", "additionalProperties": false, "required": ["name", "contract"], "properties": { "name": { "type": "string", "minLength": 1 }, "contract": { "type": "string", "minLength": 1 } } } },
          "states": { "type": "array", "description": "Complete state vocabulary for this entity and non-empty for every critical entity at ready_to_build. Include any source or destination state used by an operation transition, including an explicit not-yet-created state when creation is modeled as a transition.", "items": { "type": "string" } },
          "relationships": { "type": "array", "items": { "type": "object", "required": ["to", "cardinality", "lifecycle"], "properties": { "to": { "$ref": "#/$defs/ref" }, "cardinality": { "type": "string" }, "lifecycle": { "type": "string" } } } },
          "lifecycle_consequences": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        } },
        { "if": { "properties": { "criticality": { "const": "critical" } }, "required": ["criticality"] }, "then": { "required": ["attributes"], "properties": { "attributes": { "minItems": 1 } } } }
      ]
    },
    "operation": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        { "type": "object", "required": ["actor_refs", "preconditions", "transitions", "enforces", "outcome", "failures", "recovery"], "properties": {
          "actor_refs": { "type": "array", "description": "Must contain at least one declared actor for every critical operation at ready_to_build.", "items": { "$ref": "#/$defs/ref" } },
          "preconditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "transitions": { "type": "array", "description": "Every entity_ref must identify a declared entity. Each from and to string must exactly equal a state declared in that referenced entity's states array.", "items": { "type": "object", "required": ["entity_ref", "from", "to"], "properties": { "entity_ref": { "$ref": "#/$defs/ref" }, "from": { "type": "string", "description": "Exact declared state of entity_ref before the operation." }, "to": { "type": "string", "description": "Exact declared state of entity_ref after the operation." } } } },
          "effects": { "type": "array", "description": "Explicit observable effects for operations that do not change entity state. Every critical operation at ready_to_build must have at least one transition or at least one effect.", "items": {} },
          "enforces": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
          "outcome": { "type": "string", "description": "Required and non-empty for every critical operation at ready_to_build." },
          "failures": { "type": "array", "minItems": 1, "items": { "type": "object" } },
          "recovery": { "type": "string", "minLength": 1 },
          "destructive": { "type": "boolean" }
        } }
      ]
    },
    "workflow": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        { "type": "object", "required": ["actor_ref", "steps", "dependency_refs", "terminal_outcomes"], "properties": {
          "actor_ref": { "$ref": "#/$defs/ref" },
          "steps": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["operation_ref"], "properties": { "operation_ref": { "$ref": "#/$defs/ref" } } } },
          "dependency_refs": { "type": "array", "items": { "$ref": "#/$defs/ref" } },
          "terminal_outcomes": { "type": "array", "description": "Must be non-empty for every critical workflow at ready_to_build.", "items": { "type": "string" } }
        } }
      ]
    },
    "rule": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        { "type": "object", "required": ["rule"], "properties": { "rule": { "type": "string", "description": "Required and non-empty for every critical rule at ready_to_build." } } }
      ]
    },
    "dependency": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        { "type": "object", "required": ["type", "from", "to", "unmet_behavior"], "properties": {
          "type": { "enum": ["prerequisite", "data", "lifecycle", "reachability"], "description": "The directed graph formed by prerequisite dependencies must be acyclic." },
          "from": { "$ref": "#/$defs/ref" },
          "to": { "$ref": "#/$defs/ref" },
          "condition": { "type": "string", "minLength": 1, "description": "Observable condition under which the dependency is required." },
          "fulfillment": { "type": "string", "minLength": 1, "description": "Concrete current-slice mechanism and owner that make the dependency available, including activation and operational cadence or tolerance when relevant." },
          "unmet_behavior": { "type": "string" },
          "verification": { "type": "string", "minLength": 1, "description": "Observable proof for both met and unmet behavior." }
        } },
        { "if": { "properties": { "criticality": { "const": "critical" } }, "required": ["criticality"] }, "then": { "required": ["condition", "fulfillment", "verification"] } }
      ]
    },
    "surface": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        { "type": "object", "required": ["purpose", "primary_actor_refs", "graph_refs", "workflow_refs", "operation_refs", "contract"], "properties": {
          "purpose": { "type": "string", "minLength": 1 },
          "primary_actor_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
          "graph_refs": { "type": "array", "items": { "$ref": "#/$defs/ref" } },
          "workflow_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
          "operation_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
          "contract": { "type": "array", "minItems": 1, "description": "Reachability, journey continuity, loading, denial, stale, success, and recovery behavior relevant to this surface.", "items": { "type": "string" } }
        } }
      ]
    },
    "scenario": {
      "allOf": [
        { "$ref": "#/$defs/metadata" },
        { "type": "object", "required": ["kind", "risk_key", "given", "when", "then", "covers"], "properties": {
          "kind": { "type": "string" },
          "risk_key": { "type": "string", "description": "Must be unique across all scenarios in the contract." },
          "given": { "type": "array", "items": { "type": "string" } },
          "when": { "type": "object", "required": ["operation_ref"], "properties": { "operation_ref": { "$ref": "#/$defs/ref" } } },
          "then": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "covers": { "type": "array", "description": "Across all scenarios at ready_to_build, these refs must cover every declared critical operation, workflow, rule, and dependency.", "items": { "$ref": "#/$defs/ref" } }
        } }
      ]
    }
  }
}
