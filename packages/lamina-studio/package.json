{
  "name": "@lamina/studio",
  "version": "0.1.0",
  "description": "Semantic UX blueprint components and UX Review Studio for Lamina",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "lamina-studio": "./cli/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "preview:dev": "vite --config preview/vite.config.ts",
    "test": "npm run build",
    "setup:skills": "npx skills add ../.. --skill '*' -a cursor -y --copy"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
