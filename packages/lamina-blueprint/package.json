{
  "name": "@lamina/blueprint",
  "version": "0.1.0",
  "description": "Semantic UX blueprint components and greyscale wireframe preview for Lamina",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "lamina-blueprint": "./cli/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "preview:dev": "vite --config preview/vite.config.ts",
    "test": "node cli/validate.js examples/minimal-blueprint/.lamina/blueprints/demo 2>/dev/null || node ../../examples/minimal-blueprint/validate-test.mjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
