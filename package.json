{
  "name": "lamina",
  "version": "0.1.0",
  "description": "Product design skill for developers who build with AI coding agents",
  "author": "Aryan Iyappan",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --dir docs build",
    "test": "node scripts/verify_lamina_bundle.mjs --check structure && node tests/check_lamina_init_test.mjs && node tests/check_lamina_personas_test.mjs && node tests/lamina_write_boundary_test.mjs && node tests/harbor_benchmark_test.mjs && node tests/web_release_test.mjs && node tests/validate_run_json_test.mjs && node tests/coverage_insights_test.mjs && node tests/coverage_per_flow_test.mjs && node tests/grade_lamina_design_completion_test.mjs && node tests/grade_lamina_guardrails_test.mjs && node tests/grade_lamina_graph_eval_test.mjs && node tests/graph_fastpath_test.mjs",
    "verify:bundle": "node scripts/verify_lamina_bundle.mjs --check structure",
    "test:eval:spec": "node evals/hooks/validate-plugin.mjs && node evals/hooks/validate-skills-strict.mjs",
    "test:eval:validate": "node evals/scripts/merge-evals.mjs && node evals/scripts/validate-evals.mjs",
    "test:eval:smoke": "node evals/scripts/run-suite.mjs --smoke --agent claude-code --agent codex --agent opencode --runs 1",
    "test:eval:full": "node evals/scripts/run-suite.mjs --evals ./evals/lamina/evals.json --agent claude-code --agent codex --agent opencode --runs 3 --baseline",
    "test:eval:portable": "node evals/scripts/merge-evals.mjs && npx agent-skills-eval --config evals/agent-skills-eval.yaml",
    "test:eval:redteam": "node evals/promptfoo/build-skill-context.mjs && npx promptfoo eval -c evals/promptfoo/lamina-redteam.yaml",
    "test:eval:compat": "bash evals/hooks/compatibility-matrix.sh",
    "test:eval:aggregate": "node evals/scripts/aggregate-reports.mjs",
    "fixtures:vendor": "npm run fixtures:vendor:commerce && npm run fixtures:vendor:payload",
    "fixtures:vendor:commerce": "node evals/scripts/vendor-nextjs-fixture.mjs",
    "fixtures:vendor:payload": "node evals/scripts/vendor-payload-fixture.mjs",
    "setup:external-skills": "npx skills add ../skills --skill '*' -a cursor -y --copy",
    "bench:build": "node benchmarks/scripts/build-harbor-benchmark.mjs && harbor add --scan benchmarks/harbor/tasks --to benchmarks/harbor/dataset",
    "bench:validate": "node benchmarks/scripts/validate-harbor-benchmark.mjs",
    "bench:release:export": "node benchmarks/scripts/export-web-release.mjs",
    "bench:release:validate": "node benchmarks/scripts/validate-web-release.mjs --file benchmarks/releases/current/release.json --expect-status running && node tests/web_release_test.mjs",
    "bench:harvest": "node benchmarks/scripts/harvest-lamina-artifacts.mjs",
    "bench:aggregate": "node benchmarks/scripts/aggregate-publish-results.mjs",
    "bench:run:full": "node benchmarks/scripts/run-full-matrix.mjs",
    "bench:run:full:dry": "node benchmarks/scripts/run-full-matrix.mjs --dry-run",
    "bench:run": "node benchmarks/scripts/run-harbor-arm.mjs --arm lamina --task all --attempts 2 --concurrency 2 --model sonnet",
    "bench:run:pilot": "npm run bench:build && npm run bench:validate && npm run bench:run:pilot:matrix",
    "bench:run:pilot:matrix": "npm run bench:run:pilot:direct && npm run bench:run:pilot:checklist && npm run bench:run:pilot:lamina && npm run bench:run:pilot:control:direct && npm run bench:run:pilot:control:checklist && npm run bench:run:pilot:control",
    "bench:run:publish": "node benchmarks/scripts/run-publish-pilot.mjs",
    "bench:run:publish:dry": "node benchmarks/scripts/run-publish-pilot.mjs --dry-run",
    "bench:run:pilot:direct": "node benchmarks/scripts/run-harbor-arm.mjs --arm direct --task pilot-care-circle --attempts 2 --concurrency 1 --model sonnet",
    "bench:run:pilot:plan": "node benchmarks/scripts/run-harbor-arm.mjs --arm plan --task pilot-care-circle --attempts 2 --concurrency 1 --model sonnet",
    "bench:run:pilot:checklist": "node benchmarks/scripts/run-harbor-arm.mjs --arm checklist --task pilot-care-circle --attempts 2 --concurrency 1 --model sonnet",
    "bench:run:pilot:lamina": "node benchmarks/scripts/run-harbor-arm.mjs --arm lamina --task pilot-care-circle --attempts 2 --concurrency 1 --model sonnet",
    "bench:run:pilot:control": "node benchmarks/scripts/run-harbor-arm.mjs --arm lamina --task control-simple-list --attempts 2 --concurrency 1 --model sonnet",
    "bench:run:pilot:control:direct": "node benchmarks/scripts/run-harbor-arm.mjs --arm direct --task control-simple-list --attempts 2 --concurrency 1 --model sonnet",
    "bench:run:pilot:control:checklist": "node benchmarks/scripts/run-harbor-arm.mjs --arm checklist --task control-simple-list --attempts 2 --concurrency 1 --model sonnet",
    "bench:run:direct": "node benchmarks/scripts/run-harbor-arm.mjs --arm direct --task all --attempts 2 --concurrency 2 --model sonnet",
    "bench:run:plan": "node benchmarks/scripts/run-harbor-arm.mjs --arm plan --task all --attempts 2 --concurrency 2 --model sonnet",
    "bench:run:checklist": "node benchmarks/scripts/run-harbor-arm.mjs --arm checklist --task all --attempts 2 --concurrency 2 --model sonnet",
    "bench:run:lamina": "node benchmarks/scripts/run-harbor-arm.mjs --arm lamina --task all --attempts 2 --concurrency 2 --model sonnet",
    "bench:all": "npm run bench:build && npm run bench:validate && npm run bench:run"
  },
  "devDependencies": {
    "agent-skills-eval": "^0.1.1",
    "promptfoo": "^0.121.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
