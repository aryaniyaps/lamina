{
  "name": "lamina",
  "version": "0.1.0",
  "description": "Product design skill for developers who build with AI coding agents",
  "author": "Aryan Iyappan",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --dir docs build",
    "test": "node scripts/verify_lamina_bundle.mjs --check structure && node tests/check_lamina_init_test.mjs && node tests/check_lamina_personas_test.mjs && node tests/lamina_write_boundary_test.mjs && node tests/harbor_benchmark_test.mjs && node tests/validate_run_json_test.mjs && node tests/coverage_insights_test.mjs && node tests/coverage_per_flow_test.mjs && node tests/grade_lamina_design_completion_test.mjs",
    "verify:bundle": "node scripts/verify_lamina_bundle.mjs --check structure",
    "test:eval:spec": "node evals/hooks/validate-plugin.mjs && node evals/hooks/validate-skills-strict.mjs",
    "test:eval:validate": "node evals/scripts/merge-evals.mjs && node evals/scripts/validate-evals.mjs",
    "test:eval:smoke": "node evals/scripts/run-suite.mjs --evals ./evals/smoke/evals.json --agent claude-code --agent codex --agent opencode --runs 1",
    "test:eval:full": "node evals/scripts/run-suite.mjs --evals ./evals/lamina/evals.json --agent claude-code --agent codex --agent opencode --runs 3 --baseline",
    "test:eval:portable": "npx agent-skills-eval ./skills --baseline --config evals/lamina.config.yaml",
    "test:eval:redteam": "node evals/promptfoo/build-skill-context.mjs && npx promptfoo eval -c evals/promptfoo/lamina-redteam.yaml",
    "test:eval:compat": "bash evals/hooks/compatibility-matrix.sh",
    "test:eval:aggregate": "node evals/scripts/aggregate-reports.mjs",
    "fixtures:vendor": "npm run fixtures:vendor:commerce && npm run fixtures:vendor:payload",
    "fixtures:vendor:commerce": "node evals/scripts/vendor-nextjs-fixture.mjs",
    "fixtures:vendor:payload": "node evals/scripts/vendor-payload-fixture.mjs",
    "setup:external-skills": "npx skills add ../skills --skill '*' -a cursor -y --copy",
    "bench:build": "node benchmarks/scripts/build-harbor-benchmark.mjs && harbor add --scan benchmarks/harbor/tasks --to benchmarks/harbor/dataset",
    "bench:validate": "node benchmarks/scripts/validate-harbor-benchmark.mjs",
    "bench:run": "harbor run --path benchmarks/harbor/dataset --agent claude-code --model sonnet --resume-trajectory",
    "bench:run:raw": "harbor run --path benchmarks/harbor/dataset --include-task-name '*-raw' --agent claude-code --model sonnet --resume-trajectory",
    "bench:run:plan": "harbor run --path benchmarks/harbor/dataset --include-task-name '*-plan' --agent claude-code --model sonnet --resume-trajectory",
    "bench:run:lamina": "harbor run --path benchmarks/harbor/dataset --include-task-name '*-lamina' --agent claude-code --model sonnet --resume-trajectory --skills ./skills",
    "bench:all": "npm run bench:build && npm run bench:validate && npm run bench:run"
  },
  "devDependencies": {
    "agent-skills-eval": "^0.1.1",
    "promptfoo": "^0.121.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
