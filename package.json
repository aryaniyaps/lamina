{
  "name": "lamina",
  "version": "0.1.0",
  "description": "UX research and design knowledge for coding agents",
  "author": "Aryan Iyappan",
  "type": "module",
  "scripts": {
    "test": "node scripts/verify_lamina_bundle.mjs --check structure && node tests/check_lamina_init_test.mjs && node examples/minimal-blueprint/validate-test.mjs",
    "verify:bundle": "node scripts/verify_lamina_bundle.mjs --check structure",
    "preview:example": "lamina-blueprint preview --root examples/minimal-blueprint/.lamina/blueprints --id demo",
    "test:blueprint": "node examples/minimal-blueprint/validate-test.mjs",
    "test:eval:spec": "node evals/hooks/validate-plugin.mjs && node evals/hooks/validate-skills-strict.mjs",
    "test:eval:validate": "node evals/scripts/merge-evals.mjs && node evals/scripts/validate-evals.mjs",
    "test:eval:smoke": "node evals/scripts/run-suite.mjs --evals ./evals/smoke/evals.json --agent claude-code --agent codex --agent opencode --runs 1",
    "test:eval:full": "node evals/scripts/run-suite.mjs --evals ./evals/lamina/evals.json --agent claude-code --agent codex --agent opencode --runs 3 --baseline",
    "test:eval:portable": "npx agent-skills-eval ./skills --baseline --config evals/lamina.config.yaml",
    "test:eval:redteam": "node evals/promptfoo/build-skill-context.mjs && npx promptfoo eval -c evals/promptfoo/lamina-redteam.yaml",
    "test:eval:compat": "bash evals/hooks/compatibility-matrix.sh",
    "test:eval:aggregate": "node evals/scripts/aggregate-reports.mjs",
    "fixtures:vendor": "node evals/scripts/vendor-nextjs-fixture.mjs",
    "bench:validate": "node benchmarks/scripts/compile-suite.mjs --check",
    "bench:run": "node benchmarks/scripts/run-bench.mjs",
    "bench:score": "node benchmarks/judges/golden-coverage.mjs && node benchmarks/scripts/score-judge.mjs --mock",
    "bench:analyze": "python3 benchmarks/scripts/analyze.py",
    "bench:human-packet": "node benchmarks/scripts/export-human-packet.mjs",
    "bench:all": "npm run bench:validate && npm run bench:run -- --mock && npm run bench:score && npm run bench:analyze && npm run bench:human-packet"
  },
  "devDependencies": {
    "agent-skills-eval": "^0.1.1",
    "promptfoo": "^0.121.0"
  },
  "dependencies": {
    "@lamina/blueprint": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}

